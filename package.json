{
  "name": "fixsactransit",
  "version": "1.0.0",
  "description": "Sacramento transit reality data pipeline — fixsactransit.org",
  "type": "module",
  "scripts": {
    "deploy:gateway": "wrangler deploy workers/api-gateway/index.js --name api-gateway",
    "deploy:gtfs": "wrangler deploy workers/gtfs-score-cron/index.js --name gtfs-score-cron",
    "deploy:pain": "wrangler deploy workers/pain-factor-cron/index.js --name pain-factor-cron",
    "deploy:all": "npm run deploy:gtfs && npm run deploy:pain && npm run deploy:gateway",
    "kv:create": "wrangler kv:namespace create TRANSIT_KV",
    "kv:create-preview": "wrangler kv:namespace create TRANSIT_KV --preview"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
